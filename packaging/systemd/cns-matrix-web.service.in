# Serves the CNS matrix static dashboard on port 8888.
[Unit]
Description=CNS matrix dashboard web server
After=network.target

[Service]
Type=simple
User=__SERVICE_USER__
Group=__SERVICE_GROUP__
WorkingDirectory=/var/lib/cns-matrix/www
ExecStart=/usr/bin/python3 -m http.server 8888 --bind 0.0.0.0 --directory /var/lib/cns-matrix/www
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
